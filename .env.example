# AgroIA-RMC Environment Configuration
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit .env file to version control!

# ─── Supabase Configuration ───────────────────────────────────
# Obtain from Supabase project settings (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Service Role Key — ONLY for server-side scripts, NEVER expose to clients
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Anthropic API ────────────────────────────────────────────
# Claude API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── API Security (CRÍTICO) ───────────────────────────────────
# API secret key for authentication via X-API-Key header
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=your-secure-api-key-here

# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://myapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Google Drive Integration ─────────────────────────────────
# Path to service account JSON (preferred for production)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Legacy OAuth config (development only — use Service Account in production)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# ─── Optional Configuration ──────────────────────────────────
# Embedding model cache directory
MODEL_CACHE_DIR=.model_cache

# Logging level
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
